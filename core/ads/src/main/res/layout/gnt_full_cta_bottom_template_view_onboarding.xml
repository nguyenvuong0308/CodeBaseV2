<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.gms.ads.nativead.NativeAdView
        android:id="@+id/native_ad_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:background="@color/white">


        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/ad_notification_view"
            style="@style/AdsNotificationViewStyle"
           />

        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/media_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <RelativeLayout
            android:id="@+id/background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:paddingTop="@dimen/_50dp"
            android:background="@drawable/bg_native_onboarding">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/primary"
                style="@style/AdsTitleTextStyle"
                android:layout_width="0dp"
                android:textColor="@color/white"
                android:layout_height="wrap_content"
                android:layout_alignEnd="@+id/lCta"
                android:layout_marginStart="@dimen/_12dp"
                android:layout_alignParentStart="true"
                tools:text="Test AD : Flood-It!"/>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/body"
                style="@style/AdsBodyTextStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/primary"
                android:layout_alignStart="@+id/primary"
                android:layout_alignEnd="@+id/primary"
                android:layout_marginTop="@dimen/_4dp"
                android:gravity="center_vertical"
                android:lines="2"
                android:textColor="#E2E2E2"
                android:layout_marginBottom="@dimen/_10dp"
                tools:text="Install Flood-It App for free! Free Popurlar Casual Game "/>

            <FrameLayout
                android:id="@+id/lCta"
                android:layout_width="match_parent"
                android:paddingBottom="@dimen/_30dp"
                android:layout_height="wrap_content"
                android:background="@color/black"
                android:layout_below="@id/body">

                <FrameLayout
                    android:id="@+id/layout_cta"
                    style="@style/CtaCardViewStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/_16dp"
                    android:layout_marginTop="@dimen/_12dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/cta"
                        style="@style/CtaViewStyle"
                        tools:background="@color/colorPrimary"
                        tools:text="Cài đặt"/>
                </FrameLayout>
            </FrameLayout>
        </RelativeLayout>
    </com.google.android.gms.ads.nativead.NativeAdView>
</merge>