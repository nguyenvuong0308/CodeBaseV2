<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.gms.ads.nativead.NativeAdView
        android:id="@+id/native_ad_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/core_bg_native_ads">

        <RelativeLayout
            android:id="@+id/background"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/_14dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/ad_notification_view"
                style="@style/AdsNotificationViewStyle"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true" />

            <FrameLayout
                android:id="@+id/containerIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignStart="@+id/layout_cta"
                android:layout_alignTop="@+id/primary"
                android:layout_alignBottom="@+id/body">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/icon"
                    android:layout_width="@dimen/_46dp"
                    android:layout_height="@dimen/_46dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/_8dp"
                    android:scaleType="fitCenter"
                    android:visibility="visible" />

            </FrameLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/primary"
                style="@style/AdsTitleTextStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/ad_notification_view"
                android:layout_alignEnd="@+id/layout_cta"
                android:layout_marginTop="@dimen/_7dp"
                android:layout_toEndOf="@+id/containerIcon"
                tools:text="Test AD : Flood-It!" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/body"
                style="@style/AdsBodyTextStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/primary"
                android:layout_alignStart="@+id/primary"
                android:layout_alignEnd="@+id/primary"
                android:gravity="center_vertical"
                android:lines="2"
                tools:text="Install Flood-It App for free! Free Popurlar Casual Game " />

            <com.google.android.gms.ads.nativead.MediaView
                android:id="@+id/media_view"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_156dp"
                android:layout_below="@+id/body"
                android:layout_alignStart="@+id/layout_cta"
                android:layout_alignEnd="@+id/primary"
                android:layout_marginTop="@dimen/_7dp"
                app:layout_constraintTop_toBottomOf="@id/body" />

            <FrameLayout
                android:id="@+id/layout_cta"
                style="@style/CtaCardViewStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/media_view"
                android:layout_marginStart="@dimen/_14dp"
                android:layout_marginTop="@dimen/_10dp"
                android:layout_marginEnd="@dimen/_14dp">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/cta"
                    style="@style/CtaViewStyle"
                    tools:text="Cài đặt" />

            </FrameLayout>
        </RelativeLayout>

        <RelativeLayout
            android:paddingVertical="@dimen/_5dp"
            android:id="@+id/backgroundMini"
            android:layout_gravity="bottom"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <FrameLayout
                android:id="@+id/containerIconMini"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@+id/primaryMini"
                android:layout_alignBottom="@+id/bodyMini"
                android:layout_alignParentStart="true"
                android:layout_marginStart="@dimen/_10dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iconMini"
                    android:layout_width="@dimen/_46dp"
                    android:layout_height="@dimen/_46dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="@dimen/_8dp"
                    android:scaleType="fitCenter"
                    android:visibility="visible" />

            </FrameLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/primaryMini"
                style="@style/AdsTitleTextStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_marginTop="@dimen/_3dp"
                android:layout_marginEnd="@dimen/_7dp"
                android:layout_toStartOf="@+id/frameButtonMini"
                android:layout_toEndOf="@+id/ad_notification_viewMini"
                android:fontFamily="@font/inter_regular"
                android:textSize="@dimen/_14dp"
                android:layout_marginStart="@dimen/_5dp"
                android:textStyle="normal"
                tools:text="Test AD : Flood-It!" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/ad_notification_viewMini"
                style="@style/AdsNotificationViewStyle"
                android:background="@drawable/gnt_rounded_shape"
                android:layout_alignTop="@+id/primaryMini"
                android:layout_toEndOf="@+id/containerIconMini" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/bodyMini"
                style="@style/AdsBodyTextStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/primaryMini"
                android:layout_alignStart="@+id/ad_notification_viewMini"
                android:layout_alignEnd="@+id/primaryMini"
                android:gravity="center_vertical"
                android:lines="2"
                android:textSize="@dimen/_12dp"
                tools:text="Install Flood-It App for free! Free Popular Casual Game" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_alignTop="@+id/primaryMini"
                android:layout_alignBottom="@+id/bodyMini"
                android:id="@+id/frameButtonMini"
                android:layout_marginEnd="@dimen/_14dp"
                android:layout_alignParentEnd="true"
                android:layout_height="wrap_content">
                <FrameLayout
                    android:id="@+id/layout_ctaMini"
                    android:layout_gravity="center"
                    style="@style/CtaCardViewStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/ctaMini"
                        style="@style/CtaRightSmallViewStyle"
                        android:layout_gravity="center_vertical"
                        tools:background="@color/color_cta_banner_native_ads"
                        tools:text="Install" />
                </FrameLayout>
            </FrameLayout>



        </RelativeLayout>
    </com.google.android.gms.ads.nativead.NativeAdView>

    <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="@dimen/_24dp"
        android:background="@drawable/bg_close_collapsible"
        android:src="@drawable/ic_arrow_down_24px"
        android:tint="@color/black"
        android:id="@+id/icCloseCollapse"
        android:layout_gravity="right"
        android:layout_margin="@dimen/_10dp"
        android:layout_height="@dimen/_24dp"/>
</FrameLayout>
